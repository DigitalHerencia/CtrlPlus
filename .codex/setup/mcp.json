{
  "servers": {
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/sse",
      "headers": {
        "Authorization": "Bearer ${input:NEON_API_KEY}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["@upstash/context7-mcp@latest"],
      "env": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${input:GITHUB_TOKEN}"
      }
    },
    "microsoft-docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "next-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com",
      "headers": {
        "Authorization": "Bearer ${input:VERCEL_TOKEN}"
      }
    },
    "clerk": {
      "type": "http",
      "url": "https://mcp.clerk.com/mcp",
      "headers": {
        "Authorization": "Bearer ${input:CLERK_SECRET_KEY}"
      }
    },
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${input:NOTION_TOKEN}"
      }
    }
  },
  "inputs": [
    {
      "id": "CLERK_SECRET_KEY",
      "type": "promptString",
      "description": "Clerk secret key",
      "password": true
    },
    {
      "id": "CONTEXT7_API_KEY",
      "type": "promptString",
      "description": "Context7 API key",
      "password": true
    },
    {
      "id": "GITHUB_TOKEN",
      "type": "promptString",
      "description": "GitHub token",
      "password": true
    },
    {
      "id": "NEON_API_KEY",
      "type": "promptString",
      "description": "Neon API key",
      "password": true
    },
    {
      "id": "NOTION_TOKEN",
      "type": "promptString",
      "description": "Notion integration token",
      "password": true
    },
    {
      "id": "VERCEL_TOKEN",
      "type": "promptString",
      "description": "Vercel token",
      "password": true
    }
  ]
}
