# Runtime
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASE_URL=http://localhost:3000
DEFAULT_STORE_TIMEZONE=America/Denver
DEBUG_PRISMA_QUERIES=false

# Neon / Prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
POSTGRES_PRISMA_URL=${DATABASE_URL}
POSTGRES_URL=${DATABASE_URL}
POSTGRES_URL_NON_POOLING=${DATABASE_URL_UNPOOLED}
POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST/DB
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_DATABASE=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=
NEON_API_KEY=

# Clerk
AUTH_CLERK_SECRET_KEY=
CLERK_SECRET_KEY=
