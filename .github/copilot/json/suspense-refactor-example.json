{
    "pattern": "catalog-browse suspense segmentation",
    "sourceTarget": "features/catalog/catalog-browse-page-feature.tsx",
    "before": {
        "antiPattern": "feature-level Promise.all blocks whole page",
        "queries": [
            "searchCatalogWraps(filters, { includeHidden: canManageCatalog })",
            "getWrapCategories()"
        ],
        "renderBehavior": "single commit after slowest query"
    },
    "after": {
        "featureBehavior": "renders immediately without top-level await",
        "suspenseBoundaries": [
            {
                "region": "filters",
                "fallback": "CatalogFiltersSkeleton",
                "component": "CatalogFilters"
            },
            {
                "region": "grid",
                "fallback": "CatalogGridSkeleton",
                "component": "CatalogContent"
            },
            {
                "region": "pagination",
                "fallback": "CatalogPaginationSkeleton",
                "component": "CatalogPaginationContent"
            }
        ],
        "segmentedFile": "features/catalog/catalog-browse-parts.tsx"
    },
    "principles": [
        "no blocking awaits in page feature shell",
        "one fallback per meaningful UI region",
        "skeletons must match real layout",
        "parallel streaming over sequential waits"
    ],
    "expectedImpact": {
        "timeToHeaderMs": "0-50",
        "timeToFirstContentMs": "100-200",
        "timeToFullPageMs": "unchanged",
        "ux": "progressive fill instead of blank screen"
    },
    "adaptationChecklist": [
        "identify independent data regions",
        "extract server components per region",
        "add Suspense wrappers with specialized skeletons",
        "ensure loading.tsx reflects full-page layout",
        "remove top-level Promise.all for unrelated regions"
    ]
}