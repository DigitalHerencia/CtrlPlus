{
    "name": "ctrl-plus",
    "version": "0.1.4",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "engines": {
        "node": "24.14.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "build:check": "next build",
        "start": "next start",
        "lint": "eslint . --cache --max-warnings=0",
        "lint:fix": "eslint . --cache --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "type-check": "pnpm typecheck",
        "check": "pnpm format:check && pnpm exec prisma generate && pnpm lint && pnpm typecheck && pnpm test && pnpm prisma:validate && pnpm build",
        "ci:quality": "pnpm check",
        "fix": "pnpm format && pnpm lint:fix",
        "test": "pnpm test:unit",
        "test:unit": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "seed:demo": "node scripts/seed-demo-wraps.mjs",
        "pretest:e2e": "playwright install chromium",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "prisma:validate": "prisma validate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy"
    },
