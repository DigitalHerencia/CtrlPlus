{
    "name": "ctrl-plus",
    "version": "0.2.0",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": "24.14.0",
        "pnpm": "10.33.0"
    },
    "scripts": {
        "postinstall": "prisma generate",
        "dev": "next dev",
        "build": "prisma generate && next build",
        "build:check": "next build",
        "start": "next start",
        "lint": "eslint . --cache --max-warnings=0",
        "lint:fix": "eslint . --cache --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "type-check": "pnpm typecheck",
        "knip": "knip --no-progress",
        "knip:ci": "pnpm knip",
        "ts-prune": "ts-prune",
        "reports:refresh": "pnpm knip && pnpm ts-prune && pnpm exec tsc --noEmit --noUnusedLocals --noUnusedParameters && pnpm exec eslint . --cache --max-warnings=0",
        "validate": "pnpm lint && pnpm typecheck && pnpm prisma:validate && pnpm test",
        "check": "pnpm format:check && pnpm validate && pnpm build",
        "ci:quality": "pnpm check",
        "fix": "pnpm format && pnpm lint:fix",
        "test": "pnpm test:unit",
        "test:unit": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:ci": "pnpm typecheck && pnpm test:unit",
        "test:all": "pnpm test:unit && pnpm test:e2e",
        "test:e2e:install": "playwright install chromium",
        "seed:demo": "node scripts/seed-demo-wraps.mjs",
        "pretest:e2e": "pnpm test:e2e:install",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "prisma:validate": "prisma validate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy"
    },
    "dependencies": {
        "@clerk/nextjs": "7.2.0",
        "@gradio/client": "2.2.0",
        "@hookform/resolvers": "5.2.2",
        "@huggingface/inference": "4.13.15",
        "@neondatabase/serverless": "1.0.2",
        "@prisma/adapter-neon": "7.7.0",
        "@prisma/client": "7.7.0",
        "@radix-ui/react-dialog": "1.1.15",
        "@radix-ui/react-label": "2.1.8",
        "@radix-ui/react-separator": "1.1.8",
        "@radix-ui/react-slot": "1.2.4",
        "@radix-ui/react-tabs": "1.1.13",
        "@radix-ui/react-tooltip": "1.2.8",
        "class-variance-authority": "0.7.1",
        "cloudinary": "2.9.0",
        "clsx": "2.1.1",
        "embla-carousel-react": "8.6.0",
        "lucide-react": "1.8.0",
        "next": "16.2.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-hook-form": "7.72.1",
        "sharp": "0.34.5",
        "stripe": "22.0.1",
        "tailwind-merge": "3.5.0",
        "ws": "8.20.0",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@next/env": "16.2.3",
        "@playwright/test": "1.59.1",
        "@tailwindcss/postcss": "4.2.2",
        "@tailwindcss/typography": "0.5.19",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/jest": "30.0.0",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/ws": "8.18.1",
        "dotenv": "17.4.2",
        "eslint": "9.39.4",
        "eslint-config-next": "16.2.3",
        "eslint-config-prettier": "10.1.8",
        "jsdom": "29.0.2",
        "knip": "6.4.1",
        "postcss": "8.5.9",
        "prettier": "3.8.3",
        "prettier-plugin-tailwindcss": "0.7.2",
        "prisma": "7.7.0",
        "tailwindcss": "4.2.2",
        "ts-prune": "0.10.3",
        "typescript": "6.0.2",
        "vitest": "4.1.4"
    }
}