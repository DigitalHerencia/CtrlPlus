{
  "name": "ctrl-plus",
  "version": "0.1.2",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:check": "next build",
    "start": "next start",
    "lint": "eslint . --cache --max-warnings=0",
    "lint:fix": "eslint . --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "type-check": "pnpm typecheck",
    "check": "pnpm format:check && pnpm exec prisma generate && pnpm lint && pnpm typecheck && pnpm test && pnpm prisma:validate && pnpm build",
    "ci:quality": "pnpm check",
    "fix": "pnpm format && pnpm lint:fix",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "codex:bootstrap": "powershell -ExecutionPolicy Bypass -File .codex/setup/bootstrap-windows.ps1",
    "codex:doctor": "powershell -ExecutionPolicy Bypass -File .codex/setup/doctor.ps1",
    "prisma:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "7.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "1.0.2",
    "@prisma/adapter-neon": "7.5.0",
    "@prisma/client": "7.5.0",
    "@prisma/client-runtime-utils": "7.5.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@vercel/blob": "2.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "sharp": "0.34.5",
    "stripe": "20.4.1",
    "svix": "1.88.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "ws": "8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@next/env": "16.1.6",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "dotenv": "17.3.1",
    "eslint": "10.0.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.5.0",
    "shadcn": "4.0.7",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  }
